# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Target chat ID (group, channel, or user). Use @username or numeric ID.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Filtering ─────────────────────────────────────────────────────────────────
# Minimum Lobsters score to send a story (default: 15)
SCORE_THRESHOLD=15

# ── MySQL ─────────────────────────────────────────────────────────────────────
# When using docker-compose, set MYSQL_HOST to the service name: db
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=lobster
MYSQL_PASSWORD=lobsterpassword
MYSQL_DB=lobster_bot
